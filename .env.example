# Crowdtells — local env template. Copy to `.env` and fill in. Never commit `.env`.
# All values are optional for a basic run: `npm run seed && npm run dev` works with none of them.
# The pipeline validates without a key via `npm run generate:dry` (markets + news, no briefings).

# --- Pipeline (server-side; in CI these are GitHub Actions *secrets*, not committed) ---
# LLM briefing providers (all free-tier, OpenAI-compatible). The pipeline POOLS them for
# briefings — NVIDIA (flagship GLM-5.2) is the primary briefer, then Gemini, then Groq — so any
# one alone works; adding more stacks free capacity (per-key/per-model quotas combine).
# NVIDIA NIM key(s) ("nvapi-…"), comma-separated. The PRIMARY briefer — its flagship GLM-5.2 is
# the strongest grounded writer; free tier is just a ~40 RPM rate cap (no credit pool). One key
# calls any catalog model. Get one at build.nvidia.com. Override with NVIDIA_MODELS (default:
# z-ai/glm-5.2, meta/llama-3.1-8b-instruct).
NVIDIA_API_KEYS=
# Gemini (Google AI Studio) key(s), comma-separated. Fast #2 fallback. Free key: aistudio.google.com/apikey
GEMINI_API_KEYS=
# Groq key(s), comma-separated to rotate rate limits. Deep #3 fallback + tuned classifiers. console.groq.com.
GROQ_API_KEYS=
# Server-side Supabase writes (scoring, feed sync, digests). Service role — keep out of the client.
SUPABASE_SERVICE_KEY=
# Mailgun (digests + breaking alerts + confirmations).
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Admin Operations console alerts: notify when Gemini hits its limit and the pipeline falls
# back to Groq. ALERT_WEBHOOK is a Slack/Discord-style incoming webhook; OPS_ALERT_EMAIL gets a
# Mailgun email (reuses MAILGUN_* above). Both optional — each alert half is inert until set.
ALERT_WEBHOOK=
OPS_ALERT_EMAIL=

# --- Client (VITE_*; the anon key is a public credential — RLS protects the data) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=
# Show the newsletter UI ("true"/"false").
VITE_NEWSLETTER_ENABLED=
# Model B realtime data layer (off by default).
VITE_REALTIME_FEED=
# Optional GA4 override. The production Measurement ID is baked in and reports only from
# the live host (crowdtells.com); set this to use a different property (then it fires on
# any host), or "" to disable Google Analytics. Cloudflare Web Analytics (cookieless) is
# enabled separately in the Cloudflare dashboard and needs no env var.
VITE_GA_ID=
# Optional PostHog override. The project key is baked in and only loads from the live host;
# set this to a key to load PostHog anywhere (e.g. dogfood behaviour funnels locally), or
# "" to disable PostHog. Session-replay sampling/quota is governed in the PostHog dashboard.
VITE_POSTHOG_KEY=
