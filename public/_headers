# Security headers (defense-in-depth) on every response. Free on Cloudflare Pages,
# zero runtime cost. nosniff blocks MIME-confusion, Referrer-Policy trims leakage,
# frame-deny stops clickjacking of the SPA, HSTS pins HTTPS, and Permissions-Policy
# disables device APIs the app never uses.
# Content-Security-Policy is now ENFORCING (promoted from Report-Only after a clean
# console + a code audit of every external origin: Supabase REST https://*.supabase.co +
# Realtime wss:, Google Identity accounts.google.com script+style + ssl.gstatic.com button
# library + accounts.google.com frame, Cloudflare Web Analytics static.cloudflareinsights.com
# beacon + cloudflareinsights.com report, Google Analytics 4 www.googletagmanager.com (gtag.js)
# + *.google-analytics.com / *.analytics.google.com (collect) — these only ever load when
# VITE_GA_ID is set (GA is dormant otherwise), PostHog us.i.posthog.com (ingest) +
# us-assets.i.posthog.com (SDK array.js / session-replay recorder, in script-src + connect-src)
# with worker-src 'self' blob: for the replay compression worker — PostHog likewise only loads
# on the live host, all images via img-src https:, self for the rest).
# The TWO pre-paint inline scripts in index.html (the theme-setter + the intensity-setter)
# are each allowlisted by sha256 hash rather than 'unsafe-inline'. ⚠️ If either EVER changes
# — or a new bare <script> is added to index.html — its hash MUST be added here (sha256 of
# the bytes between <script></script>) or it's BLOCKED on the live site. The csp.test.ts
# guard now checks EVERY bare inline script, so it fails loudly on any drift.
# To debug a future block, temporarily append `-Report-Only` to the header name.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://accounts.google.com https://cloudflareinsights.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://us.i.posthog.com https://us-assets.i.posthog.com; script-src 'self' https://accounts.google.com https://ssl.gstatic.com https://static.cloudflareinsights.com https://www.googletagmanager.com https://us-assets.i.posthog.com 'sha256-NfmlKLlMmHNvDg5ifkQGfYn5NAJrZJxyTxK24MYDsNQ=' 'sha256-Xk6PX6I0iG15Bg3PbWRHgbthtG5XqYVSM+uzENgWlPg='; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://accounts.google.com; font-src 'self'; worker-src 'self' blob:; frame-src https://accounts.google.com; base-uri 'self'; object-src 'none'

# Cloudflare Pages cache policy. Without this, Pages serves everything with
# `max-age=0, must-revalidate`, so even content-hashed assets get re-validated on
# every request — a needless round-trip for every returning reader.

# Vite fingerprints these filenames (the hash changes when the content changes),
# so a given URL is immutable — cache it for a year.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts never change under their path.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted country flags — content at /flags/{iso}.svg never changes.
/flags/*
  Cache-Control: public, max-age=31536000, immutable

# Per-story OG images are slug-named (not fingerprinted) and change rarely; a day
# of caching with background revalidation keeps social scrapers + repeat views cheap
# without pinning a stale card for long.
/og/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Feeds + sitemaps are rewritten every pipeline run — keep them fresh.
/feed.json
  Cache-Control: public, max-age=300, must-revalidate
/feed.xml
  Cache-Control: public, max-age=300, must-revalidate
/sitemap.xml
  Cache-Control: public, max-age=300, must-revalidate
/sitemap-news.xml
  Cache-Control: public, max-age=300, must-revalidate

# HTML pages (/, /s/*, /topic/*, …) intentionally fall through to the Pages
# default (revalidate every request): the feed updates every ~15 min and we want
# readers to see fresh briefings; a 304 revalidation is cheap.
